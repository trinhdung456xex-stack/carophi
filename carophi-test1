-- =====================================================
-- MAIN FARM LOOP (ĐÃ CẢI TIẾN)
-- =====================================================

RunService.Heartbeat:Connect(function()
    if not Config.AutoFarm.Enabled then return end

    pcall(function()
        -- Tìm NPC gần nhất
        local nearest, minDist = nil, math.huge
        for _, enemy in ipairs(Workspace.Enemies:GetChildren()) do
            if enemy:FindFirstChild("HumanoidRootPart") and enemy.Humanoid.Health > 0 then
                local dist = (rootPart.Position - enemy.HumanoidRootPart.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = enemy
                end
            end
        end

        if nearest and minDist < 300 then
            State.CurrentTarget = nearest
            -- Tween mượt
            Utility:TweenTo(nearest.HumanoidRootPart.CFrame * CFrame.new(0, 8, 10), 0.6)
        end
    end)
end)

