-- =====================================================

local function CreateToggle(parent, text, default, callback)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,45)
    f.BackgroundTransparency = 1
    f.Parent = parent

    local label = Instance.new("TextLabel")
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 15
    label.Size = UDim2.new(0.65,0,1,0)
    label.BackgroundTransparency = 1
    label.Parent = f

    local tog = Instance.new("TextButton")
    tog.Size = UDim2.new(0,50,0,26)
    tog.Position = UDim2.new(0.8,0,0.5,-13)
    tog.BackgroundColor3 = default and Color3.fromRGB(0,200,100) or Color3.fromRGB(80,80,80)
    tog.Text = ""
    tog.Parent = f
    Instance.new("UICorner", tog).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", tog)
    knob.Size = UDim2.new(0,20,0,20)
    knob.Position = default and UDim2.new(0.55,0,0.5,-10) or UDim2.new(0.08,0,0.5,-10)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    tog.MouseButton1Click:Connect(function()
        default = not default
        TweenService:Create(tog, TweenInfo.new(0.25), {BackgroundColor3 = default and Color3.fromRGB(0,200,100) or Color3.fromRGB(80,80,80)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.25), {Position = default and UDim2.new(0.55,0,0.5,-10) or UDim2.new(0.08,0,0.5,-10)}):Play()
        callback(default)
    end)
end

