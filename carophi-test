local function CreateToggle(parent, text, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, 50)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local label = Instance.new("TextLabel")
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Size = UDim2.new(0.7,0,1,0)
    label.BackgroundTransparency = 1
    label.Parent = frame

    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 55, 0, 28)
    toggle.Position = UDim2.new(0.82, 0, 0.5, -14)
    toggle.BackgroundColor3 = default and Color3.fromRGB(0, 180, 80) or Color3.fromRGB(70,70,70)
    toggle.Text = ""
    toggle.Parent = frame
    Instance.new("UICorner", toggle).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", toggle)
    knob.Size = UDim2.new(0,22,0,22)
    knob.Position = UDim2.new(default and 0.55 or 0.05, 0, 0.5, -11)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    toggle.MouseButton1Click:Connect(function()
        default = not default
        TweenService:Create(toggle, TweenInfo.new(0.25), {BackgroundColor3 = default and Color3.fromRGB(0,180,80) or Color3.fromRGB(70,70,70)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.25), {Position = default and UDim2.new(0.55,0,0.5,-11) or UDim2.new(0.05,0,0.5,-11)}):Play()
        callback(default)
    end)
end

