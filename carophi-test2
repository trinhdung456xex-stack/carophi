local function CreateToggle(parent, text, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1,0,0,50)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local label = Instance.new("TextLabel")
    label.Text = text
    label.TextColor3 = Color3.new(1,1,1)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 16
    label.Size = UDim2.new(0.65,0,1,0)
    label.BackgroundTransparency = 1
    label.Parent = frame

    local switch = Instance.new("TextButton")
    switch.Size = UDim2.new(0, 52, 0, 28)
    switch.Position = UDim2.new(0.78,0,0.5,-14)
    switch.BackgroundColor3 = default and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(80,80,80)
    switch.Text = ""
    switch.Parent = frame
    Instance.new("UICorner", switch).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", switch)
    knob.Size = UDim2.new(0,22,0,22)
    knob.Position = default and UDim2.new(0.55,0,0.5,-11) or UDim2.new(0.05,0,0.5,-11)
    knob.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    switch.MouseButton1Click:Connect(function()
        default = not default
        TweenService:Create(switch, TweenInfo.new(0.25), {BackgroundColor3 = default and Color3.fromRGB(0,255,100) or Color3.fromRGB(80,80,80)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.25), {Position = default and UDim2.new(0.55,0,0.5,-11) or UDim2.new(0.05,0,0.5,-11)}):Play()
        callback(default)
    end)
end

