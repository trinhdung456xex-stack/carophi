RunService.Heartbeat:Connect(function()
    pcall(function()
        if Config.AutoFarm.Enabled and State.IsFarming then
            local nearest, minDist = nil, 9999
            for _, enemy in ipairs(Workspace.Enemies:GetChildren()) do
                if enemy:FindFirstChild("HumanoidRootPart") and enemy.Humanoid.Health > 0 then
                    local dist = (rootPart.Position - enemy.HumanoidRootPart.Position).Magnitude
                    if dist < minDist then minDist = dist; nearest = enemy end
                end
            end
            if nearest and minDist < 250 then
                Utility:TweenTo(nearest.HumanoidRootPart.CFrame * CFrame.new(0,6,9), 0.7)
            end
        end

        -- ESP
        if Config.Visual.ESP_NPC then
            for _, enemy in ipairs(Workspace.Enemies:GetChildren()) do
                if enemy:FindFirstChild("HumanoidRootPart") then
                    Utility:CreateESP(enemy, Color3.fromRGB(255, 80, 80))
                end
            end
        end
    end)
end)

